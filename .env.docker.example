# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=planner_ai

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_me_32_chars_minimum_secret
JWT_REFRESH_SECRET=change_me_32_chars_minimum_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────
# Your domain or VPS IP (used for CORS)
CORS_URL=http://yourdomain.com

# ─── Frontend (imgbb image uploads) ──────────────────────
VITE_IMGBB_API_KEY=your_imgbb_api_key
VITE_IMGBB_UPLOAD_URL=https://api.imgbb.com/1/upload

# ─── Telegram contact form ────────────────────────────────
VITE_TG_BOT_TOKEN=
VITE_TG_CHAT_ID=

# ─── Google OAuth (optional) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://yourdomain.com/api/auth/google/callback

# ─── Payment providers (optional) ────────────────────────
CLICK_SECRET=
PAYME_KEY=

# ─── Email / SMTP (optional) ─────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# ─── Bootstrap admin account ─────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_strong_admin_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
